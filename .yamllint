---
extends: default

rules:
  braces:
    max-spaces-inside: 1
  line-length:
    max: 200
    level: warning
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    allowed-values:
      - "true"
      - "false"
    check-keys: false
  comments:
    require-starting-space: true
    ignore-shebangs: true
    min-spaces-from-content: 1
  comments-indentation: false
  document-start:
    present: true
  indentation:
    spaces: 2
    indent-sequences: true

ignore:
  - .git/
  - collections/
  - .venv/
  - venv/
