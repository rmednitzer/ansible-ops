# Ansible managed - do not edit manually
# AIDE configuration for Ubuntu 24.04 LTS
# Compliance: NIS2 Art 21.2(a), GDPR Art 32, CTL-002

database_in=file:{{ aide_db_path }}
database_out=file:{{ aide_db_new_path }}
database_new=file:{{ aide_db_new_path }}

# Reporting
report_url=file:{{ aide_report_path }}
report_url=stdout

# Rule definitions
# p: permissions, i: inode, n: link count, u: user, g: group
# s: size, b: block count, m: mtime, c: ctime, S: check for growing size
# md5/sha256/sha512: hash algorithms (POL-003: no MD5 for compliance)
NORMAL = p+i+n+u+g+s+b+m+c+sha256+sha512
DIR = p+i+n+u+g
PERMS = p+i+u+g
LOG = p+u+g+S
DATAONLY = p+u+g+s+sha256+sha512

# Monitored directories
{% for dir in aide_monitored_dirs %}
{{ dir }} NORMAL
{% endfor %}

# Excluded paths
{% for dir in aide_excluded_dirs %}
!{{ dir }}
{% endfor %}

# Standard exclusions for dynamic content
!/var/log
!/var/spool
!/var/cache
!/var/tmp
!/tmp
!/run
!/proc
!/sys
!/dev
