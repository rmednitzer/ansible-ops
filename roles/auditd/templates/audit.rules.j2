# Ansible managed - do not edit manually
# Audit rules for Ubuntu 24.04 LTS
# Compliance: NIS2 Art 21.2(a), GDPR Art 5(2), CTL-0003, CIS Benchmark

# Remove all existing rules
-D

# Set buffer and failure mode
-b {{ auditd_buffer_size }}
-f {{ auditd_failure_mode }}
--backlog_wait_time 60000

{% if auditd_cis_rules %}
# === CIS Benchmark-aligned rules ===

# Time change events (forensic correlation integrity — CTL-0003)
-a always,exit -F arch=b64 -S adjtimex -S settimeofday -S clock_settime -k time-change
-a always,exit -F arch=b32 -S adjtimex -S settimeofday -S stime -S clock_settime -k time-change
-w /etc/localtime -p wa -k time-change

# User/group modification events (NIS2 Art 21.2(i) — access control audit)
-w /etc/group -p wa -k identity
-w /etc/passwd -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity

# Network configuration changes
-a always,exit -F arch=b64 -S sethostname -S setdomainname -k system-locale
-a always,exit -F arch=b32 -S sethostname -S setdomainname -k system-locale
-w /etc/issue -p wa -k system-locale
-w /etc/issue.net -p wa -k system-locale
-w /etc/hosts -p wa -k system-locale
-w /etc/netplan -p wa -k system-locale

# Login/logout events (GDPR Art 5(2) — accountability)
-w /var/log/faillog -p wa -k logins
-w /var/log/lastlog -p wa -k logins
-w /var/log/tallylog -p wa -k logins
-w /var/run/utmp -p wa -k session
-w /var/log/wtmp -p wa -k logins
-w /var/log/btmp -p wa -k logins

# Discretionary access control permission modification
-a always,exit -F arch=b64 -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b64 -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b64 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=4294967295 -k perm_mod

# Unauthorized access attempts
-a always,exit -F arch=b64 -S open -S openat -S truncate -S ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b32 -S open -S openat -S truncate -S ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b64 -S open -S openat -S truncate -S ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b32 -S open -S openat -S truncate -S ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=4294967295 -k access

# Privileged commands (sudo, su, etc.)
-w /usr/bin/sudo -p x -k privileged
-w /usr/bin/su -p x -k privileged
-w /usr/bin/chage -p x -k privileged
-w /usr/bin/chfn -p x -k privileged
-w /usr/bin/chsh -p x -k privileged
-w /usr/bin/newgrp -p x -k privileged
-w /usr/sbin/adduser -p x -k privileged
-w /usr/sbin/useradd -p x -k privileged
-w /usr/sbin/userdel -p x -k privileged
-w /usr/sbin/usermod -p x -k privileged
-w /usr/sbin/groupadd -p x -k privileged
-w /usr/sbin/groupdel -p x -k privileged
-w /usr/sbin/groupmod -p x -k privileged
-w /usr/sbin/visudo -p x -k privileged

# Sudoers file changes
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers

# Kernel module events
-w /sbin/insmod -p x -k modules
-w /sbin/rmmod -p x -k modules
-w /sbin/modprobe -p x -k modules
-a always,exit -F arch=b64 -S init_module -S delete_module -S finit_module -k modules

# File deletion by users
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=4294967295 -k delete
-a always,exit -F arch=b32 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=4294967295 -k delete

# Audit configuration changes
-w /etc/audit/ -p wa -k auditconfig
-w /etc/audisp/ -p wa -k auditconfig
{% endif %}

{% if auditd_compliance_rules %}
# === NIS2/GDPR/CRA compliance rules ===

# PAM and authentication configuration (NIS2 Art 21.2(i))
-w /etc/pam.d/ -p wa -k pam_config
-w /etc/security/ -p wa -k security_config
-w /etc/login.defs -p wa -k login_config
-w /etc/ssh/sshd_config -p wa -k sshd_config

# Filesystem mount events (CIS + data exfiltration detection)
-a always,exit -F arch=b64 -S mount -S umount2 -F auid>=1000 -F auid!=4294967295 -k mounts
-a always,exit -F arch=b32 -S mount -S umount -S umount2 -F auid>=1000 -F auid!=4294967295 -k mounts

# Cron and scheduled tasks (change management — POL-05)
-w /etc/crontab -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
-w /etc/cron.daily/ -p wa -k cron
-w /etc/cron.hourly/ -p wa -k cron
-w /etc/cron.weekly/ -p wa -k cron
-w /etc/cron.monthly/ -p wa -k cron
-w /var/spool/cron/ -p wa -k cron
-w /etc/systemd/system/ -p wa -k systemd_config

# Network configuration (NIS2 Art 21.2(e) — network security)
-w /etc/netplan/ -p wa -k network_config
-w /etc/ufw/ -p wa -k firewall_config
-w /etc/nftables.conf -p wa -k firewall_config

# Cryptographic material changes (POL-03 — cryptography policy)
-w /etc/ssl/ -p wa -k crypto_config
-w /etc/ssh/ -p wa -k crypto_config

# Hostname and DNS changes
-w /etc/hostname -p wa -k hostname
-w /etc/resolv.conf -p wa -k dns_config

# Package management (NIS2 Art 21.2(e) — vulnerability management)
-w /usr/bin/dpkg -p x -k software_mgmt
-w /usr/bin/apt -p x -k software_mgmt
-w /usr/bin/apt-get -p x -k software_mgmt

# Process execution tracking for privileged tools
-w /usr/bin/passwd -p x -k privileged
-w /usr/bin/ssh-keygen -p x -k crypto_key_gen
-w /usr/bin/gpg -p x -k crypto_key_gen
-w /usr/bin/gpg2 -p x -k crypto_key_gen

# Systemctl changes (service management audit)
-w /usr/bin/systemctl -p x -k service_mgmt
{% endif %}

{% for rule in auditd_custom_rules %}
{{ rule }}
{% endfor %}

# Make the configuration immutable (requires reboot to change)
-e 2
