# Ansible managed - do not edit manually
# Fail2Ban local configuration

[DEFAULT]
ignoreip = {{ fail2ban_ignoreip }}
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
backend  = {{ fail2ban_backend }}
banaction = {{ fail2ban_banaction }}
{% if fail2ban_notify_email %}
destemail = {{ fail2ban_notify_email }}
sender    = {{ fail2ban_sender_email }}
action    = {{ fail2ban_notify_action }}
{% endif %}

{% for jail in fail2ban_jails %}
[{{ jail.name }}]
enabled  = {{ jail.enabled | ternary('true', 'false') }}
port     = {{ jail.port }}
filter   = {{ jail.filter }}
maxretry = {{ jail.maxretry | default(fail2ban_maxretry) }}
bantime  = {{ jail.bantime | default(fail2ban_bantime) }}
{% if jail.logpath is defined %}
logpath  = {{ jail.logpath }}
{% endif %}

{% endfor %}
{% for jail in fail2ban_custom_jails %}
[{{ jail.name }}]
{% for key, value in jail.items() if key != 'name' %}
{{ key }} = {{ value }}
{% endfor %}

{% endfor %}
