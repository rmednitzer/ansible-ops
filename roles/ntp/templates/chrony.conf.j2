# Ansible managed - do not edit manually
# Chrony configuration for Ubuntu 24.04 LTS
# Compliance: CTL-003, POL-002, ISO 27001:2022 A.8.17

# NTP servers
{% for server in ntp_servers %}
server {{ server }}
{% endfor %}

{% if ntp_pools | length > 0 %}
# NTP pools
{% for pool in ntp_pools %}
pool {{ pool }}
{% endfor %}
{% endif %}

{% if ntp_nts_enabled and ntp_nts_servers | length > 0 %}
# NTS-authenticated servers (POL-003 — cryptographic integrity of time source)
{% for server in ntp_nts_servers %}
server {{ server }}
{% endfor %}
{% endif %}

# Record the rate at which the system clock gains/losses time
driftfile {{ ntp_driftfile }}

# Allow the system clock to be stepped in the first three updates
# if its offset is larger than {{ ntp_makestep_threshold }} second
makestep {{ ntp_makestep_threshold }} {{ ntp_makestep_limit }}

{% if ntp_rtcsync %}
# Enable kernel synchronization of the real-time clock (RTC)
rtcsync
{% endif %}

# Logging
logdir {{ ntp_logdir }}
log tracking measurements statistics

# Specify directory for Unix domain command socket
keyfile /etc/chrony/chrony.keys
leapsectz right/UTC

{% if ntp_nts_enabled %}
# NTS key material
ntsdumpdir /var/lib/chrony
{% endif %}

{% if ntp_allow_networks | length > 0 %}
# Allow NTP client access from specified networks
{% for network in ntp_allow_networks %}
allow {{ network }}
{% endfor %}
{% endif %}
